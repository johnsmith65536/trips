          144.8667,-38.5167,0
        </coordinates>
      </LineString>
    </Placemark>

    <Placemark>
      <name>🟣 菲利普岛返墨尔本（Day5）</name>
      <description>返程，约140km，1.5小时，还车后飞霍巴特</description>
      <styleUrl>#s-inland-line</styleUrl>
      <LineString>
        <tessellate>1</tessellate>
        <coordinates>
          145.2335,-38.4522,0
          145.3672,-38.5306,0
